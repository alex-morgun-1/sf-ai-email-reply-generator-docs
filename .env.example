# ============================================================
# Playwright E2E Test Environment — AI Email Reply Generator
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.

# ------------------------------------------------------------------
# Salesforce Scratch / Dev Org
# ------------------------------------------------------------------
SF_ORG_URL=https://orgfarm-2384b18009-dev-ed.develop.my.salesforce.com
SF_ADMIN_USERNAME=epic.30beb5bc4b5e@orgfarm.salesforce.com
SF_ADMIN_PASSWORD=

# Admin App direct URL (Lightning page for the AI Reply admin panel)
SF_ADMIN_APP_URL=https://orgfarm-2384b18009-dev-ed.develop.my.salesforce.com/lightning/n/aiemailreply__AI_Email_Reply_Admin

# ------------------------------------------------------------------
# AI Provider API Keys
# Each key is stored as the value of the External Credential
# Authentication Parameter (Authorization header) in Salesforce Setup.
# Format: "Bearer <key>"  (include the word "Bearer " for OpenAI / Anthropic / xAI).
# Google Gemini also uses Bearer token auth via OAuth2-style header.
# ------------------------------------------------------------------

# OpenAI  (Named Credential: AI_Email_Reply_Provider)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic  (Named Credential: AI_Email_Reply_Anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-haiku-20240307

# Google Gemini  (Named Credential: AI_Email_Reply_Google)
GOOGLE_API_KEY=AIza...
GOOGLE_MODEL=gemini-1.5-flash

# xAI / Grok  (Named Credential: AI_Email_Reply_XAI)
XAI_API_KEY=xai-...
XAI_MODEL=grok-beta

# ------------------------------------------------------------------
# Named Credential URLs (set once in Salesforce Setup)
# These defaults are correct for each provider's chat-completions API.
# ------------------------------------------------------------------
OPENAI_NC_URL=https://api.openai.com/v1/chat/completions
ANTHROPIC_NC_URL=https://api.anthropic.com/v1/messages
GOOGLE_NC_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent
XAI_NC_URL=https://api.x.ai/v1/chat/completions

# ------------------------------------------------------------------
# External Credential name shared by all Named Credentials
# ------------------------------------------------------------------
SF_EXTERNAL_CREDENTIAL_NAME=AI_Email_Reply_ExtCred
SF_EXTERNAL_CREDENTIAL_PRINCIPAL=AI_Email_Reply_User
